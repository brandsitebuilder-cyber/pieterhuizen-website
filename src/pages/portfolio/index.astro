---
import BaseLayout from '../../layouts/BaseLayout.astro';
const p = [{e:'🏗️',t:'Rezoning',h:'Somerset West Mixed-Use',d:'24-unit development. Approved in 8 months.',l:'Somerset West',y:'2024'},{e:'📐',t:'Subdivision',h:'Stellenbosch Residential',d:'4,000m² into four erven.',l:'Stellenbosch',y:'2024'},{e:'📋',t:'Departure',h:'Cape Town Commercial',d:'CBD office departure. 4 months.',l:'Cape Town',y:'2024'},{e:'🔓',t:'Title Deed',h:'Helderberg Restriction',d:'Removed 50-year restriction for 6-unit dev.',l:'Helderberg',y:'2023'},{e:'🏘️',t:'Rezoning',h:'Cape Town Multi-Unit',d:'SR1 to GR4. 18-unit apartment block.',l:'Cape Town',y:'2023'},{e:'📊',t:'Consolidation',h:'Somerset West Erf Assembly',d:'Three erven for retirement village.',l:'Somerset West',y:'2023'}];
---
<BaseLayout title="Portfolio — Approved Projects" description="Approved town planning projects across Cape Town, Somerset West and Stellenbosch.">
  <section class="min-h-[30vh] flex items-center"><div class="wrap pt-32 pb-12"><span class="tag mb-6">Portfolio</span><h1>Approved <span class="text-brand">projects</span></h1></div></section>
  <section class="py-24 bg-surface"><div class="wrap"><div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
    {p.map(x => (
      <div class="card"><div class="h-40 mb-5 flex items-center justify-center text-5xl bg-bg rounded-xl">{x.e}</div><span class="tag mb-3">{x.t}</span><h3 class="text-lg mb-2">{x.h}</h3><p class="text-muted text-sm mb-4">{x.d}</p><p class="text-muted text-xs">📍 {x.l} · {x.y}</p></div>
    ))}
  </div></div></section>
</BaseLayout>