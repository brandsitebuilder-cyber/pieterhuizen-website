---
import BaseLayout from '../../layouts/BaseLayout.astro';
const projects = [{emoji:'🏗️',tag:'Rezoning',title:'Somerset West Mixed-Use',desc:'Rezoning to Mixed-Use for 24-unit development. Approved in 8 months.',location:'Somerset West',year:'2024'},{emoji:'📐',tag:'Subdivision',title:'Stellenbosch Residential',desc:'4,000m² erf divided into four residential erven with title registration.',location:'Stellenbosch',year:'2024'},{emoji:'📋',tag:'Departure',title:'Cape Town Commercial',desc:'Building line relaxation and parking departure for CBD office fit-out.',location:'Cape Town',year:'2024'},{emoji:'🔓',tag:'Title Deed',title:'Helderberg Restriction Removal',desc:'Removed 50-year-old single-dwelling restriction for 6-unit development.',location:'Helderberg',year:'2023'},{emoji:'🏘️',tag:'Rezoning',title:'Cape Town Multi-Unit',desc:'SR1 to GR4 rezoning enabling 18-unit apartment block.',location:'Cape Town',year:'2023'},{emoji:'📊',tag:'Consolidation',title:'Somerset West Erf Assembly',desc:'Three erven consolidated for retirement village project.',location:'Somerset West',year:'2023'}];
---
<BaseLayout title="Portfolio — Approved Town Planning Projects" description="Browse our portfolio of approved town planning projects across Cape Town, Somerset West and Stellenbosch.">
  <section class="relative pt-28 pb-16"><div class="wrap"><span class="tag mb-4">Our Work</span><h1 class="mt-4">Approved Projects<br /><span class="gradient-text">Western Cape</span></h1></div></section>
  <section class="section-sm"><div class="wrap"><div class="grid md:grid-cols-2 lg:grid-cols-3 gap-3">
    {projects.map(p => (
      <div class="card"><div class="bg-surface rounded-xl h-40 mb-5 flex items-center justify-center text-5xl">{p.emoji}</div><span class="text-accent text-xs font-semibold uppercase tracking-wider">{p.tag}</span><h3 class="text-lg mt-2 mb-2">{p.title}</h3><p class="text-text-secondary text-sm leading-relaxed mb-5">{p.desc}</p><p class="text-text-muted text-xs">📍 {p.location} · {p.year}</p></div>
    ))}
  </div></div></section>
  <section class="relative overflow-hidden py-24 text-center border-t border-border"><div class="wrap max-w-xl relative z-10"><h2 class="mb-4">Ready to Be Our Next<br /><span class="gradient-text">Success Story?</span></h2><p class="text-text-secondary text-lg mb-10">Every project starts with a conversation.</p><a href="/contact/" class="btn-primary text-[15px] px-8 py-4">Start Your Project →</a></div></section>
</BaseLayout>