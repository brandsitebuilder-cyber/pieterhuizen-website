---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Town Planners Stellenbosch — Rezoning & Land Use" description="Specialist town planning consultants for Stellenbosch and the Cape Winelands.">
  <section class="relative pt-28 pb-16"><div class="wrap"><div class="max-w-3xl"><span class="tag mb-4">Areas We Serve</span><h1 class="mt-4">Town Planners<br /><span class="gradient-text">Stellenbosch</span></h1><p class="text-text-secondary text-lg mt-6 max-w-xl">Specialist town planning consultants for Stellenbosch and the Cape Winelands.</p></div></div></section>
  <section class="section-sm"><div class="wrap max-w-3xl">
    <h2 class="mb-3">Services & Coverage</h2><div class="hr-accent mb-6"></div>
    <div class="grid md:grid-cols-2 gap-3 mb-12"><div class="card"><h3 class="text-lg mb-4">Services</h3><ul class="space-y-2.5"><li class="flex items-center gap-2 text-sm"><span class="w-1.5 h-1.5 bg-accent rounded-full shrink-0"></span> <a href="/services/rezoning/" class="text-text-secondary hover:text-accent transition-colors">Rezoning Stellenbosch</a></li><li class="flex items-center gap-2 text-sm"><span class="w-1.5 h-1.5 bg-accent rounded-full shrink-0"></span> <a href="/services/subdivisions/" class="text-text-secondary hover:text-accent transition-colors">Subdivisions</a></li><li class="flex items-center gap-2 text-sm"><span class="w-1.5 h-1.5 bg-accent rounded-full shrink-0"></span> <a href="/services/departures/" class="text-text-secondary hover:text-accent transition-colors">Departures</a></li><li class="flex items-center gap-2 text-sm text-text-muted"><span class="w-1.5 h-1.5 bg-border rounded-full shrink-0"></span> Heritage Applications</li></ul></div><div class="card"><h3 class="text-lg mb-4">Areas</h3><ul class="space-y-2.5"><li class="flex items-center gap-2 text-sm text-text-muted"><span class="w-1.5 h-1.5 bg-border rounded-full shrink-0"></span> Stellenbosch Central</li><li class="flex items-center gap-2 text-sm text-text-muted"><span class="w-1.5 h-1.5 bg-border rounded-full shrink-0"></span> Techno Park</li><li class="flex items-center gap-2 text-sm text-text-muted"><span class="w-1.5 h-1.5 bg-border rounded-full shrink-0"></span> Jonkershoek Valley</li><li class="flex items-center gap-2 text-sm text-text-muted"><span class="w-1.5 h-1.5 bg-border rounded-full shrink-0"></span> Paradyskloof</li><li class="flex items-center gap-2 text-sm text-text-muted"><span class="w-1.5 h-1.5 bg-border rounded-full shrink-0"></span> Jamestown & Raithby</li></ul></div></div>
    <h2 class="mb-3 mt-12">Why Choose Us</h2><div class="hr-accent mb-6"></div><div class="grid sm:grid-cols-2 gap-3"><div class="flex items-start gap-3 text-text-secondary text-sm"><span class="text-accent font-bold shrink-0">01</span> <span>Heritage — SA's most stringent protection frameworks</span></div><div class="flex items-start gap-3 text-text-secondary text-sm"><span class="text-accent font-bold shrink-0">02</span> <span>Zoning — Expert knowledge for different precincts</span></div><div class="flex items-start gap-3 text-text-secondary text-sm"><span class="text-accent font-bold shrink-0">03</span> <span>SDF — Higher approval rates with aligned applications</span></div><div class="flex items-start gap-3 text-text-secondary text-sm"><span class="text-accent font-bold shrink-0">04</span> <span>Aesthetic Committee — Design-sensitive project experience</span></div></div>
  </div></section>
  <section class="relative overflow-hidden py-24 text-center border-t border-border"><div class="wrap max-w-xl relative z-10"><h2 class="mb-4">Need a Town Planner?</h2><p class="text-text-secondary text-lg mb-10">Free consultation — honest advice on your best path forward.</p><a href="/contact/" class="btn-primary text-[15px] px-8 py-4">Get Your Free Consultation →</a></div></section>
</BaseLayout>