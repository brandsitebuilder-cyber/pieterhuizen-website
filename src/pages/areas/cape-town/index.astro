<div class="wrap pb-24"><div class="grid md:grid-cols-3 gap-px bg-border-subtle">
<div class="bg-bg p-6"><p class="text-text-secondary text-sm">Cape Town Metropolitan</p></div>
<div class="bg-bg p-6"><p class="text-text-secondary text-sm">City Bowl</p></div>
<div class="bg-bg p-6"><p class="text-text-secondary text-sm">Atlantic Seaboard</p></div>
<div class="bg-bg p-6"><p class="text-text-secondary text-sm">Southern Suburbs</p></div>
<div class="bg-bg p-6"><p class="text-text-secondary text-sm">Northern Suburbs</p></div>
<div class="bg-bg p-6"><p class="text-text-secondary text-sm">Blaauwberg</p></div>
