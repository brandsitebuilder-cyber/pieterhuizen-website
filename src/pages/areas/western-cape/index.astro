---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Town Planners Western Cape — Rezoning & Land Use" description="Serving the entire Western Cape — Cape Town, Winelands, Overberg, West Coast.">
  <section class="relative pt-28 pb-16"><div class="wrap"><div class="max-w-3xl"><span class="tag mb-4">Areas We Serve</span><h1 class="mt-4">Town Planners<br /><span class="gradient-text">Western Cape</span></h1><p class="text-text-secondary text-lg mt-6 max-w-xl">Serving the entire Western Cape — Cape Town, Winelands, Overberg, West Coast.</p></div></div></section>
  <section class="section-sm"><div class="wrap max-w-3xl">
    <h2 class="mb-3">Services & Coverage</h2><div class="hr-accent mb-6"></div>
    <div class="grid md:grid-cols-2 gap-3 mb-12"><div class="card"><h3 class="text-lg mb-4">Cape Metro</h3><ul class="space-y-2.5"><li class="flex items-center gap-2 text-sm"><span class="w-1.5 h-1.5 bg-accent rounded-full shrink-0"></span> <a href="/areas/cape-town/" class="text-text-secondary hover:text-accent transition-colors">Cape Town</a></li><li class="flex items-center gap-2 text-sm"><span class="w-1.5 h-1.5 bg-accent rounded-full shrink-0"></span> <a href="/areas/somerset-west/" class="text-text-secondary hover:text-accent transition-colors">Somerset West</a></li><li class="flex items-center gap-2 text-sm text-text-muted"><span class="w-1.5 h-1.5 bg-border rounded-full shrink-0"></span> Blaauwberg & Milnerton</li><li class="flex items-center gap-2 text-sm text-text-muted"><span class="w-1.5 h-1.5 bg-border rounded-full shrink-0"></span> Southern Peninsula</li></ul></div><div class="card"><h3 class="text-lg mb-4">Winelands & Beyond</h3><ul class="space-y-2.5"><li class="flex items-center gap-2 text-sm"><span class="w-1.5 h-1.5 bg-accent rounded-full shrink-0"></span> <a href="/areas/stellenbosch/" class="text-text-secondary hover:text-accent transition-colors">Stellenbosch</a></li><li class="flex items-center gap-2 text-sm text-text-muted"><span class="w-1.5 h-1.5 bg-border rounded-full shrink-0"></span> Paarl & Franschhoek</li><li class="flex items-center gap-2 text-sm text-text-muted"><span class="w-1.5 h-1.5 bg-border rounded-full shrink-0"></span> Hermanus & Overberg</li><li class="flex items-center gap-2 text-sm text-text-muted"><span class="w-1.5 h-1.5 bg-border rounded-full shrink-0"></span> West Coast & Swartland</li></ul></div></div>
    
  </div></section>
  <section class="relative overflow-hidden py-24 text-center border-t border-border"><div class="wrap max-w-xl relative z-10"><h2 class="mb-4">Need a Town Planner?</h2><p class="text-text-secondary text-lg mb-10">Free consultation — honest advice on your best path forward.</p><a href="/contact/" class="btn-primary text-[15px] px-8 py-4">Get Your Free Consultation →</a></div></section>
</BaseLayout>