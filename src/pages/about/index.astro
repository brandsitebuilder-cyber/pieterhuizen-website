---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="About — Town Planners Cape Town" description="Established town planning consultants serving Cape Town, Somerset West and Stellenbosch since 2015.">
  <section class="min-h-[50vh] flex items-center"><div class="wrap pt-32 pb-16 max-w-3xl"><p class="tag mb-6">About Us</p><h1>Cape Town's Trusted<br /><span class="text-gold">Town Planning Consultants</span></h1><p class="text-ink-muted text-lg mt-6 max-w-xl">Since 2015, providing expert town planning services across Cape Town, Somerset West, Stellenbosch and the Western Cape.</p></div></section>
  <section class="section-sm bg-white"><div class="wrap-narrow">
    <h2 class="mb-3">Who We Are</h2><div class="accent-line"></div><p class="text-ink-muted text-lg leading-relaxed mt-6 mb-16">Cape Town-based town planning consultancy with deep expertise in Western Cape municipal planning frameworks, zoning schemes and land use management systems. Over 50 approved applications and a decade of experience.</p>
    <h2 class="mb-3">Our Approach</h2><div class="accent-line"></div>
    <div class="grid md:grid-cols-3 gap-6 mt-8">
      <div class="card"><h3 class="mb-3">Assess</h3><p class="text-ink-muted text-sm">We understand your property, goals and the regulatory landscape before recommending any path forward.</p></div>
      <div class="card"><h3 class="mb-3">Strategize</h3><p class="text-ink-muted text-sm">Every application is crafted with meticulous attention to municipal requirements, maximising approval probability.</p></div>
      <div class="card"><h3 class="mb-3">Partner</h3><p class="text-ink-muted text-sm">We stay with you through the entire process — from consultation to final municipal approval and beyond.</p></div>
    </div>
  </div></section>
  <section class="py-24 md:py-32 text-center bg-cream-dark"><div class="wrap-narrow"><h2 class="mb-4">Work With Western Cape's<br /><span class="text-gold">Town Planning Experts</span></h2><p class="text-ink-muted text-lg mb-10">Every project begins with a free consultation.</p><a href="/contact/" class="btn-gold text-base px-10 py-4">Get Your Free Consultation</a></div></section>
</BaseLayout>