---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="About — Town Planners Cape Town" description="Established town planning consultants serving Cape Town, Somerset West and Stellenbosch since 2015.">
  <section class="min-h-[50vh] flex items-center"><div class="wrap pt-32 pb-16 max-w-2xl"><span class="tag mb-6">About</span><h1>Cape Town's trusted<br /><span class="text-brand">town planning</span><br />consultants</h1><p class="text-muted text-lg mt-6">Since 2015. 50+ approved applications. Deep expertise in Western Cape municipal planning.</p></div></section>
  <section class="py-24 bg-surface"><div class="wrap"><div class="grid md:grid-cols-3 gap-4">
    <div class="card text-center py-12"><div class="text-5xl mb-4">🔍</div><h3 class="mb-2">Assess</h3><p class="text-muted text-sm">Understand your property, goals & regulatory landscape.</p></div>
    <div class="card text-center py-12"><div class="text-5xl mb-4">📋</div><h3 class="mb-2">Strategize</h3><p class="text-muted text-sm">Craft applications that maximise approval probability.</p></div>
    <div class="card text-center py-12"><div class="text-5xl mb-4">🤝</div><h3 class="mb-2">Partner</h3><p class="text-muted text-sm">Stay with you through to final municipal approval.</p></div>
  </div></div></section>
  <section class="py-32 bg-ink text-center"><div class="narrow"><h2 class="text-white mb-4">Work with us</h2><p class="text-white/40 text-lg mb-10">Every project begins with a free consultation.</p><a href="/contact/" class="btn-gold text-base px-10 py-4">Get Started</a></div></section>
</BaseLayout>