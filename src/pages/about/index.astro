---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="About — Town Planners Cape Town" description="Learn about Pieterhuizen Planning, established town planning consultants serving Cape Town, Somerset West and Stellenbosch since 2015.">
  <section class="relative pt-28 pb-16"><div class="wrap"><div class="max-w-3xl"><span class="tag mb-4">About Us</span><h1 class="mt-4">Cape Town's Trusted<br /><span class="gradient-text">Town Planning Consultants</span></h1><p class="text-text-secondary text-lg mt-6 max-w-xl">Since 2015, providing expert town planning services across Cape Town, Somerset West, Stellenbosch and the Western Cape.</p></div></div></section>
  <section class="section-sm"><div class="wrap max-w-3xl">
    <h2 class="mb-3">Who We Are</h2><div class="hr-accent mb-6"></div><p class="text-text-secondary text-lg leading-relaxed mb-12">Cape Town-based town planning consultancy with deep expertise in Western Cape municipal planning frameworks, zoning schemes and land use management systems.</p>
    <h2 class="mb-3 mt-16">Our Approach</h2><div class="hr-accent mb-6"></div>
    <div class="grid md:grid-cols-3 gap-3 mb-12">
      <div class="card text-center"><div class="text-4xl mb-4">🔍</div><h3 class="mb-2">Assess</h3><p class="text-text-secondary text-sm">We understand your property, goals, and the regulatory landscape before recommending any path forward.</p></div>
      <div class="card text-center"><div class="text-4xl mb-4">📋</div><h3 class="mb-2">Strategize</h3><p class="text-text-secondary text-sm">Every application is crafted with meticulous attention to municipal requirements, maximising approval probability.</p></div>
      <div class="card text-center"><div class="text-4xl mb-4">🤝</div><h3 class="mb-2">Partner</h3><p class="text-text-secondary text-sm">We stay with you through the entire process — from consultation to final municipal approval and beyond.</p></div>
    </div>
    <h2 class="mb-3 mt-16">Expertise</h2><div class="hr-accent mb-6"></div>
    <div class="grid sm:grid-cols-2 gap-2"><div class="flex items-center gap-3 text-text-secondary text-sm"><span class="text-accent">✓</span> Rezoning — all municipalities</div><div class="flex items-center gap-3 text-text-secondary text-sm"><span class="text-accent">✓</span> Subdivisions & consolidations</div><div class="flex items-center gap-3 text-text-secondary text-sm"><span class="text-accent">✓</span> Departure & consent use</div><div class="flex items-center gap-3 text-text-secondary text-sm"><span class="text-accent">✓</span> Title deed restriction removal</div><div class="flex items-center gap-3 text-text-secondary text-sm"><span class="text-accent">✓</span> Development potential reports</div><div class="flex items-center gap-3 text-text-secondary text-sm"><span class="text-accent">✓</span> Zoning compliance</div><div class="flex items-center gap-3 text-text-secondary text-sm"><span class="text-accent">✓</span> Policy advisory</div><div class="flex items-center gap-3 text-text-secondary text-sm"><span class="text-accent">✓</span> Objection representation</div></div>
  </div></section>
  <section class="relative overflow-hidden py-24 text-center border-t border-border"><div class="wrap max-w-xl relative z-10"><h2 class="mb-4">Work With Western Cape's<br /><span class="gradient-text">Town Planning Experts</span></h2><p class="text-text-secondary text-lg mb-10">Every project begins with a free consultation.</p><a href="/contact/" class="btn-primary text-[15px] px-8 py-4">Get Your Free Consultation →</a></div></section>
</BaseLayout>