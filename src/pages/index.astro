---
import BaseLayout from '../layouts/BaseLayout.astro';
const schema = {"@context":"https://schema.org","@type":"LocalBusiness","name":"Pieterhuizen Planning","description":"Expert Town Planners Cape Town — Rezoning, Subdivisions, Land Use Applications","address":{"@type":"PostalAddress","addressLocality":"Cape Town","addressRegion":"Western Cape","addressCountry":"ZA"},"areaServed":["Cape Town","Somerset West","Stellenbosch","Helderberg Basin","Western Cape"],"hasOfferCatalog":{"@type":"OfferCatalog","name":"Town Planning Services","itemListElement":[{"@type":"Offer","itemOffered":{"@type":"Service","name":"Rezoning Applications"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Subdivisions & Consolidations"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Departures & Consent Use"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Title Deed Restriction Removal"}},{"@type":"Offer","itemOffered":{"@type":"Service","name":"Property Development Reports"}}]}};
---

<BaseLayout title="Expert Town Planners Cape Town — Rezoning, Subdivisions & Land Use" description="Professional town planning consultants in Cape Town. Rezoning, subdivisions, departures and land use applications across the Western Cape. Free consultation." schema={schema}>
  
  <!-- ═══════ HERO ═══════ -->
  <section class="relative min-h-screen flex items-center overflow-hidden">
    <div class="orb w-[800px] h-[800px] bg-accent/20 -top-40 -right-40"></div>
    <div class="orb w-[500px] h-[500px] bg-accent/10 bottom-[20%] -left-[10%]"></div>
    
    <div class="wrap relative z-10 pt-32 pb-20">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Left: Text -->
        <div>
          <div class="flex flex-wrap gap-2 mb-8">
            <span class="tag">⭐ 50+ Approved</span>
            <span class="tag">📍 Western Cape</span>
          </div>
          <h1 class="text-text mb-6">
            Expert<br /><span class="gradient-text">Town Planners</span><br />Cape Town
          </h1>
          <p class="text-text-secondary text-lg leading-relaxed max-w-lg mb-10">
            Rezoning · Subdivisions · Land Use — guiding developers, architects 
            and property investors through every municipal application across 
            Somerset West, Stellenbosch and the Western Cape.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/contact/" class="btn-primary text-[15px] px-7 py-3.5">Get Your Free Consultation →</a>
            <a href="/portfolio/" class="btn-outline text-[15px] px-7 py-3.5">View Portfolio</a>
          </div>
        </div>
        <!-- Right: Visual element -->
        <div class="hidden lg:block relative">
          <div class="aspect-square rounded-3xl border border-border bg-card/50 overflow-hidden relative">
            <!-- Decorative grid pattern -->
            <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #D4A24E 1px, transparent 1px); background-size: 24px 24px;"></div>
            <!-- Stats overlay -->
            <div class="absolute inset-0 flex flex-col items-center justify-center p-12">
              <div class="text-9xl font-black gradient-text mb-4">50+</div>
              <p class="text-text-secondary text-sm tracking-wider uppercase">Projects Approved</p>
              <div class="hr-accent my-6 mx-auto"></div>
              <div class="grid grid-cols-2 gap-8 text-center">
                <div><div class="text-3xl font-bold text-text">10+</div><p class="text-text-muted text-xs mt-1">Years</p></div>
                <div><div class="text-3xl font-bold text-text">100%</div><p class="text-text-muted text-xs mt-1">Compliance</p></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-bg to-transparent pointer-events-none"></div>
  </section>

  <!-- ═══════ SERVICES BENTO ═══════ -->
  <section class="section">
    <div class="wrap">
      <div class="mb-16">
        <span class="tag mb-4">What We Do</span>
        <h2 class="mt-4 mb-4">Town Planning<br /><span class="gradient-text">Services — Western Cape</span></h2>
        <div class="hr-accent"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-3">
        <!-- Large card: Rezoning -->
        <a href="/services/rezoning/" class="md:col-span-2 card-hover no-underline text-inherit group flex flex-col justify-between min-h-[280px]">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center text-xl">🏗️</div>
              <span class="text-text-muted text-xs uppercase tracking-wider">Core Service</span>
            </div>
            <h3 class="text-2xl mb-3 group-hover:text-accent transition-colors">Rezoning & Land Use Applications</h3>
            <p class="text-text-secondary text-sm leading-relaxed max-w-md">Full rezoning applications for Cape Town, Somerset West and Stellenbosch. From feasibility assessment to final municipal approval — we manage every step.</p>
          </div>
          <span class="text-accent text-sm font-medium mt-6 inline-flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">Learn more →</span>
        </a>

        <!-- Small card: Subdivisions -->
        <a href="/services/subdivisions/" class="card-hover no-underline text-inherit group">
          <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center text-xl mb-4">📐</div>
          <h3 class="text-lg mb-2 group-hover:text-accent transition-colors">Subdivisions & Consolidations</h3>
          <p class="text-text-secondary text-sm">Erf divisions, consolidations and sectional title schemes across the Western Cape.</p>
        </a>

        <!-- Departures -->
        <a href="/services/departures/" class="card-hover no-underline text-inherit group">
          <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center text-xl mb-4">📋</div>
          <h3 class="text-lg mb-2 group-hover:text-accent transition-colors">Departures & Consent Use</h3>
          <p class="text-text-secondary text-sm">Building line relaxations, height, coverage and parking departures.</p>
        </a>

        <!-- Title Deed -->
        <a href="/services/title-deed-restrictions/" class="card-hover no-underline text-inherit group">
          <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center text-xl mb-4">🔓</div>
          <h3 class="text-lg mb-2 group-hover:text-accent transition-colors">Title Deed Restrictions</h3>
          <p class="text-text-secondary text-sm">Remove outdated restrictive conditions and unlock development potential.</p>
        </a>

        <!-- Large card: Development Reports -->
        <a href="/services/development-reports/" class="md:col-span-2 card-hover no-underline text-inherit group flex flex-col justify-between min-h-[200px]">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center text-xl">📊</div>
              <span class="text-text-muted text-xs uppercase tracking-wider">Due Diligence</span>
            </div>
            <h3 class="text-2xl mb-3 group-hover:text-accent transition-colors">Development Potential Reports</h3>
            <p class="text-text-secondary text-sm leading-relaxed max-w-lg">Know exactly what your property can legally become before you invest. Comprehensive reports delivered in 5–7 working days.</p>
          </div>
          <span class="text-accent text-sm font-medium mt-6 inline-flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════ STATS BAR ═══════ -->
  <div class="hr"></div>
  <div class="wrap py-14">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div><div class="text-5xl font-black gradient-text mb-1">50+</div><p class="text-text-muted text-sm">Approved Applications</p></div>
      <div><div class="text-5xl font-black gradient-text mb-1">10+</div><p class="text-text-muted text-sm">Years Experience</p></div>
      <div><div class="text-5xl font-black gradient-text mb-1">5.0</div><p class="text-text-muted text-sm">Client Rating</p></div>
      <div><div class="text-5xl font-black gradient-text mb-1">100%</div><p class="text-text-muted text-sm">Compliance Rate</p></div>
    </div>
  </div>
  <div class="hr"></div>

  <!-- ═══════ LOCATIONS ═══════ -->
  <section class="section">
    <div class="wrap">
      <div class="mb-16">
        <span class="tag mb-4">Where We Work</span>
        <h2 class="mt-4 mb-4">Trusted Across<br /><span class="gradient-text">The Western Cape</span></h2>
        <div class="hr-accent"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-3">
        <a href="/areas/cape-town/" class="card-hover no-underline text-inherit group">
          <h3 class="text-xl mb-3 group-hover:text-accent transition-colors">Cape Town</h3>
          <p class="text-text-secondary text-sm leading-relaxed">City Bowl · Atlantic Seaboard · Southern & Northern Suburbs</p>
        </a>
        <a href="/areas/somerset-west/" class="card-hover no-underline text-inherit group">
          <h3 class="text-xl mb-3 group-hover:text-accent transition-colors">Somerset West</h3>
          <p class="text-text-secondary text-sm leading-relaxed">Helderberg Basin · Strand · Gordon's Bay</p>
        </a>
        <a href="/areas/stellenbosch/" class="card-hover no-underline text-inherit group">
          <h3 class="text-xl mb-3 group-hover:text-accent transition-colors">Stellenbosch</h3>
          <p class="text-text-secondary text-sm leading-relaxed">Heritage-sensitive planning · Cape Winelands</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════ TESTIMONIALS ═══════ -->
  <section class="py-24 md:py-32 border-t border-border">
    <div class="wrap">
      <div class="mb-16">
        <span class="tag mb-4">Testimonials</span>
        <h2 class="mt-4">Trusted by Developers<br /><span class="gradient-text">& Property Professionals</span></h2>
      </div>
      <div class="grid md:grid-cols-3 gap-4">
        <div class="card">
          <div class="text-accent text-xs tracking-[0.3em] mb-5">★★★★★</div>
          <p class="text-text-secondary leading-relaxed text-sm italic mb-6">"Navigated a complex rezoning for our Somerset West development that others said couldn't be done. Approved in 6 months."</p>
          <p class="text-text text-sm font-semibold">Property Developer, Somerset West</p>
        </div>
        <div class="card">
          <div class="text-accent text-xs tracking-[0.3em] mb-5">★★★★★</div>
          <p class="text-text-secondary leading-relaxed text-sm italic mb-6">"As an architect, I rely on their departure applications. They understand design intent and consistently get results."</p>
          <p class="text-text text-sm font-semibold">Architect, Cape Town</p>
        </div>
        <div class="card">
          <div class="text-accent text-xs tracking-[0.3em] mb-5">★★★★★</div>
          <p class="text-text-secondary leading-relaxed text-sm italic mb-6">"Their development report saved us from a bad investment and pointed us toward a property with 3× the upside."</p>
          <p class="text-text text-sm font-semibold">Property Investor, Stellenbosch</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ CTA ═══════ -->
  <section class="relative overflow-hidden py-32 text-center">
    <div class="orb w-[600px] h-[600px] bg-accent/15 top-[50%] left-[50%] -translate-x-1/2 -translate-y-1/2"></div>
    <div class="wrap relative z-10 max-w-xl mx-auto">
      <h2 class="mb-6">Ready to Unlock Your<br /><span class="gradient-text">Property's Potential?</span></h2>
      <p class="text-text-secondary text-lg mb-10">Free land use assessment — response within 24 hours.</p>
      <a href="/contact/" class="btn-primary text-[15px] px-8 py-4">Request Your Free Consultation →</a>
    </div>
  </section>
</BaseLayout>
