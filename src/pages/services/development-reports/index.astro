---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Development Potential Reports — Town Planners Cape Town" description="Know exactly what your property can become before you invest.">
  <section class="relative pt-28 pb-16"><div class="wrap"><div class="max-w-3xl"><span class="tag mb-4">Services</span><h1 class="mt-4">Development Potential<br /><span class="gradient-text">Reports</span></h1><p class="text-text-secondary text-lg mt-6 max-w-xl">Know exactly what your property can become before you invest.</p></div></div></section>
  <section class="section-sm"><div class="wrap max-w-3xl">
    <h2 class="mb-3">Overview</h2><div class="hr-accent mb-6"></div>
    <p class="text-text-secondary text-lg leading-relaxed mb-10">Know exactly what your property can become before you invest.</p>
    <div class="grid md:grid-cols-2 gap-3 mb-12"><div class="card"><h3 class="text-lg mb-4">Reports Cover</h3><ul class="space-y-2 text-text-secondary text-sm"><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Current zoning & rights</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Maximum bulk & coverage</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Subdivision potential</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Title deed restrictions</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Heritage & environmental overlays</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Policy framework assessment</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Rezoning probability</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Development pathway</li></ul></div><div class="card"><h3 class="text-lg mb-4">Who Needs This</h3><ul class="space-y-2 text-text-secondary text-sm"><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Property developers</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Property investors</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Architects</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Homeowners</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Institutions</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Financial institutions</li></ul></div></div>
    <h2 class="mb-3 mt-12">Our Process</h2><div class="hr-accent mb-6"></div>
    <div class="grid sm:grid-cols-4 gap-3 mb-12">
      <div class="card text-center"><div class="text-3xl mb-3">1️⃣</div><h3 class="text-sm font-semibold mb-1">Assessment</h3><p class="text-text-muted text-xs">Evaluate zoning, policies and approval likelihood</p></div>
      <div class="card text-center"><div class="text-3xl mb-3">2️⃣</div><h3 class="text-sm font-semibold mb-1">Preparation</h3><p class="text-text-muted text-xs">Full motivation report with documentation</p></div>
      <div class="card text-center"><div class="text-3xl mb-3">3️⃣</div><h3 class="text-sm font-semibold mb-1">Submission</h3><p class="text-text-muted text-xs">Lodge with municipality, manage process</p></div>
      <div class="card text-center"><div class="text-3xl mb-3">4️⃣</div><h3 class="text-sm font-semibold mb-1">Approval</h3><p class="text-text-muted text-xs">Secure approval, ensure compliance</p></div>
    </div>
    
  </div></section>
  <section class="relative overflow-hidden py-24 text-center border-t border-border"><div class="wrap max-w-xl relative z-10"><h2 class="mb-4">Need This Service?</h2><p class="text-text-secondary text-lg mb-10">Free assessment — honest advice on what's possible.</p><a href="/contact/" class="btn-primary text-[15px] px-8 py-4">Get Your Free Assessment →</a></div></section>
</BaseLayout>