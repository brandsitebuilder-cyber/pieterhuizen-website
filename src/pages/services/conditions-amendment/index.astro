---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Amendment of Conditions" description="Amendment of Conditions for Cape Town, Somerset West and Stellenbosch.">
  <section class="min-h-[30vh] flex items-center"><div class="wrap pt-32 pb-12"><p class="tag mb-6">Services</p><h1>Amendment of Conditions<br /><span class="text-gold">Conditions of Approval</span></h1></div></section>
  <section class="section-sm bg-white"><div class="wrap-narrow"><h2 class="mb-3">Our Services</h2><div class="accent-line"></div><div class="card mt-8"><ul class="space-y-3"><li class="flex items-start gap-2 text-ink-muted text-sm"><span class="text-gold shrink-0">—</span> Amendment of zoning conditions</li><li class="flex items-start gap-2 text-ink-muted text-sm"><span class="text-gold shrink-0">—</span> Modification of approval conditions</li><li class="flex items-start gap-2 text-ink-muted text-sm"><span class="text-gold shrink-0">—</span> Extension of validity periods</li><li class="flex items-start gap-2 text-ink-muted text-sm"><span class="text-gold shrink-0">—</span> Removal of outdated conditions</li><li class="flex items-start gap-2 text-ink-muted text-sm"><span class="text-gold shrink-0">—</span> Compliance timeline adjustments</li></ul></div></div></section>
  <section class="py-24 text-center bg-cream-dark"><div class="wrap-narrow"><h2 class="mb-4">Need This Service?</h2><p class="text-ink-muted text-lg mb-10">Contact us today.</p><a href="/contact/" class="btn-gold text-base px-10 py-4">Request a Quote</a></div></section>
</BaseLayout>