---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Amendment of Conditions — Town Planners Cape Town" description="Amendment of Conditions for Cape Town, Somerset West and Stellenbosch.">
  <section class="relative pt-28 pb-16"><div class="wrap"><span class="tag mb-4">Services</span><h1 class="mt-4">Amendment of Conditions<br /><span class="gradient-text">Conditions of Approval</span></h1></div></section>
  <section class="section-sm"><div class="wrap max-w-3xl"><h2 class="mb-3">Our Services</h2><div class="hr-accent mb-6"></div><div class="card"><ul class="space-y-3"><li class="flex items-start gap-2 text-text-secondary text-sm"><span class="text-accent shrink-0">✓</span> Amendment of zoning conditions</li><li class="flex items-start gap-2 text-text-secondary text-sm"><span class="text-accent shrink-0">✓</span> Modification of approval conditions</li><li class="flex items-start gap-2 text-text-secondary text-sm"><span class="text-accent shrink-0">✓</span> Extension of validity periods</li><li class="flex items-start gap-2 text-text-secondary text-sm"><span class="text-accent shrink-0">✓</span> Removal of outdated conditions</li><li class="flex items-start gap-2 text-text-secondary text-sm"><span class="text-accent shrink-0">✓</span> Compliance timeline adjustments</li></ul></div></div></section>
  <section class="relative overflow-hidden py-24 text-center border-t border-border"><div class="wrap max-w-xl relative z-10"><h2 class="mb-4">Need This Service?</h2><p class="text-text-secondary text-lg mb-10">Fast turnaround. Contact us today.</p><a href="/contact/" class="btn-primary text-[15px] px-8 py-4">Request a Quote →</a></div></section>
</BaseLayout>