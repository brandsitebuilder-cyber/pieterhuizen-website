---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Title Deed Restrictions — Town Planners Cape Town" description="Title Deed Restrictions for Cape Town, Somerset West and Stellenbosch.">
  <section class="min-h-[35vh] flex items-center"><div class="wrap pt-32 pb-12 max-w-2xl"><span class="tag mb-6">Services</span><div class="text-6xl mb-6">🔓</div><h1>Title Deed Restrictions<br /><span class="text-brand">Removal</span></h1></div></section>
  <section class="py-24 bg-surface"><div class="narrow">
    <div class="card mb-6"><h3 class="mb-4">What we offer</h3><p class="text-muted leading-relaxed">Expert town planning services across Cape Town, Somerset West, Stellenbosch and the Western Cape. We manage the entire application process — from initial assessment to final municipal approval. Free initial consultation available.</p></div>
    <div class="grid sm:grid-cols-3 gap-4 mt-8">
      <div class="card text-center py-8"><div class="text-3xl mb-3">1</div><h3 class="text-sm">Assessment</h3><p class="text-muted text-xs mt-1">Evaluate zoning & viability</p></div>
      <div class="card text-center py-8"><div class="text-3xl mb-3">2</div><h3 class="text-sm">Application</h3><p class="text-muted text-xs mt-1">Prepare & submit</p></div>
      <div class="card text-center py-8"><div class="text-3xl mb-3">3</div><h3 class="text-sm">Approval</h3><p class="text-muted text-xs mt-1">Secure & comply</p></div>
    </div>
  </div></section>
  <section class="py-32 bg-ink text-center"><div class="narrow"><h2 class="text-white mb-4">Need this service?</h2><p class="text-white/40 text-lg mb-10">Free assessment — honest advice.</p><a href="/contact/" class="btn-gold text-base px-10 py-4">Get Started</a></div></section>
</BaseLayout>