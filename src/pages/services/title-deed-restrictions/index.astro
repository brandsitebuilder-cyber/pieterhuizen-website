import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Title Deed Restriction Removal — Town Planners" description="Remove restrictive title deed conditions. Unlock development potential on your property. Town planners Western Cape.">
<section class="min-h-[50vh] flex items-center"><div class="wrap pt-28 pb-16"><span class="tag mb-10">Services · Title Deed</span><h1 class="mb-6">Title deed <span class="text-accent">restrictions</span></h1><p class="text-text-muted text-lg leading-relaxed max-w-lg">Remove or amend restrictive conditions on your property's title deed. Unlock what your land can really do.</p></div></section>
<div class="wrap pb-24"><div class="grid md:grid-cols-3 gap-px bg-border-subtle">
<div class="bg-bg p-8"><h3 class="mb-2">Restrictive conditions</h3><p class="text-text-muted text-sm">Old title deed clauses limiting use, density, building materials or design — removed via formal application.</p></div>
<div class="bg-bg p-8"><h3 class="mb-2">Conditions of approval</h3><p class="text-text-muted text-sm">Remove outdated conditions from previous approvals that no longer serve a planning purpose.</p></div>
<div class="bg-bg p-8"><h3 class="mb-2">Amendment of conditions</h3><p class="text-text-muted text-sm">Modify conditions to better suit your current development plans — without a full new application.</p></div>
<div class="bg-bg p-8"><h3 class="mb-2">Property buyers</h3><p class="text-text-muted text-sm">Found the perfect property but the title deed blocks your plans? We can help remove those restrictions.</p></div>
<div class="bg-bg p-8"><h3 class="mb-2">Developers & investors</h3><p class="text-text-muted text-sm">Restrictive conditions kill deals. Get them removed before you commit capital.</p></div>
<div class="bg-bg p-8"><h3 class="mb-2">Attorneys</h3><p class="text-text-muted text-sm">We handle the planning side of title deed amendments — you handle the conveyancing.</p></div>
</div></div>
<section class="py-32 text-center border-t border-border-subtle"><div class="narrow"><h2 class="mb-6">Title deed <span class="text-accent">holding you back</span>?</h2><p class="text-text-muted text-lg mb-10">Free review of your title deed conditions. Response within 24 hours.</p><a href="/contact/" class="btn-primary text-base px-8 py-4">Get Your Free Consultation</a></div></section>
</BaseLayout>