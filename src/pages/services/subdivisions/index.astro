---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Subdivisions & Consolidations — Town Planners Cape Town" description="Subdivisions & for Cape Town, Somerset West and Stellenbosch.">
  <section class="min-h-[30vh] flex items-center"><div class="wrap pt-32 pb-12 max-w-3xl"><p class="tag mb-6">Services</p><h1>Subdivisions &<br /><span class="text-gold">Consolidations</span></h1></div></section>
  <section class="section-sm bg-white"><div class="wrap-narrow">
    <h2 class="mb-3">Overview</h2><div class="accent-line"></div>
    <p class="text-ink-muted text-lg leading-relaxed mt-6">Expert town planning services for Cape Town, Somerset West, Stellenbosch and the Western Cape. We manage the entire application process — from initial assessment to final municipal approval.</p>
    <div class="grid md:grid-cols-2 gap-6 mt-12"><div class="card"><h3 class="mb-4">Subdivisions</h3><ul class="space-y-2.5 text-ink-muted text-sm"><li class="flex items-start gap-2"><span class="text-gold shrink-0">—</span> Residential erf subdivisions</li><li class="flex items-start gap-2"><span class="text-gold shrink-0">—</span> Agricultural land subdivisions</li><li class="flex items-start gap-2"><span class="text-gold shrink-0">—</span> Commercial/industrial divisions</li><li class="flex items-start gap-2"><span class="text-gold shrink-0">—</span> Sectional title schemes</li><li class="flex items-start gap-2"><span class="text-gold shrink-0">—</span> Township establishment</li></ul></div><div class="card"><h3 class="mb-4">Consolidations</h3><ul class="space-y-2.5 text-ink-muted text-sm"><li class="flex items-start gap-2"><span class="text-gold shrink-0">—</span> Residential erf consolidations</li><li class="flex items-start gap-2"><span class="text-gold shrink-0">—</span> Commercial site amalgamations</li><li class="flex items-start gap-2"><span class="text-gold shrink-0">—</span> Erf assembly</li><li class="flex items-start gap-2"><span class="text-gold shrink-0">—</span> Title deed alignment</li><li class="flex items-start gap-2"><span class="text-gold shrink-0">—</span> Zoning reconciliation</li></ul></div></div>
    <h2 class="mb-3 mt-16">Our Process</h2><div class="accent-line"></div>
    <div class="grid sm:grid-cols-4 gap-4 mt-8">
      <div class="card text-center"><div class="font-serif text-2xl text-gold font-bold mb-2">1</div><h3 class="text-sm font-semibold">Assessment</h3><p class="text-ink-muted text-xs mt-1">Evaluate zoning & approval likelihood</p></div>
      <div class="card text-center"><div class="font-serif text-2xl text-gold font-bold mb-2">2</div><h3 class="text-sm font-semibold">Preparation</h3><p class="text-ink-muted text-xs mt-1">Full motivation with documentation</p></div>
      <div class="card text-center"><div class="font-serif text-2xl text-gold font-bold mb-2">3</div><h3 class="text-sm font-semibold">Submission</h3><p class="text-ink-muted text-xs mt-1">Lodge & manage the process</p></div>
      <div class="card text-center"><div class="font-serif text-2xl text-gold font-bold mb-2">4</div><h3 class="text-sm font-semibold">Approval</h3><p class="text-ink-muted text-xs mt-1">Secure approval & compliance</p></div>
    </div>
  </div></section>
  <section class="py-24 text-center bg-cream-dark"><div class="wrap-narrow"><h2 class="mb-4">Need This Service?</h2><p class="text-ink-muted text-lg mb-10">Free assessment — honest advice on what's possible.</p><a href="/contact/" class="btn-gold text-base px-10 py-4">Get Your Free Assessment</a></div></section>
</BaseLayout>