---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="Subdivisions & Consolidations — Town Planners Cape Town" description="Expert subdivision and consolidation services for Somerset West, Stellenbosch and Cape Town.">
  <section class="relative pt-28 pb-16"><div class="wrap"><div class="max-w-3xl"><span class="tag mb-4">Services</span><h1 class="mt-4">Subdivisions &<br /><span class="gradient-text">Consolidations</span></h1><p class="text-text-secondary text-lg mt-6 max-w-xl">Expert subdivision and consolidation services for Somerset West, Stellenbosch and Cape Town.</p></div></div></section>
  <section class="section-sm"><div class="wrap max-w-3xl">
    <h2 class="mb-3">Overview</h2><div class="hr-accent mb-6"></div>
    <p class="text-text-secondary text-lg leading-relaxed mb-10">Expert subdivision and consolidation services for Somerset West, Stellenbosch and Cape Town.</p>
    <div class="grid md:grid-cols-2 gap-3 mb-12"><div class="card"><h3 class="text-lg mb-4">Subdivisions</h3><ul class="space-y-2 text-text-secondary text-sm"><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Residential erf subdivisions</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Agricultural land subdivisions</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Commercial/industrial erf divisions</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Sectional title schemes</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Township establishment</li></ul></div><div class="card"><h3 class="text-lg mb-4">Consolidations</h3><ul class="space-y-2 text-text-secondary text-sm"><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Residential erf consolidations</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Commercial site amalgamations</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Erf assembly for developments</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Title deed alignment</li><li class="flex items-start gap-2"><span class="text-accent shrink-0">✓</span> Zoning reconciliation</li></ul></div></div>
    <h2 class="mb-3 mt-12">Our Process</h2><div class="hr-accent mb-6"></div>
    <div class="grid sm:grid-cols-4 gap-3 mb-12">
      <div class="card text-center"><div class="text-3xl mb-3">1️⃣</div><h3 class="text-sm font-semibold mb-1">Assessment</h3><p class="text-text-muted text-xs">Evaluate zoning, policies and approval likelihood</p></div>
      <div class="card text-center"><div class="text-3xl mb-3">2️⃣</div><h3 class="text-sm font-semibold mb-1">Preparation</h3><p class="text-text-muted text-xs">Full motivation report with documentation</p></div>
      <div class="card text-center"><div class="text-3xl mb-3">3️⃣</div><h3 class="text-sm font-semibold mb-1">Submission</h3><p class="text-text-muted text-xs">Lodge with municipality, manage process</p></div>
      <div class="card text-center"><div class="text-3xl mb-3">4️⃣</div><h3 class="text-sm font-semibold mb-1">Approval</h3><p class="text-text-muted text-xs">Secure approval, ensure compliance</p></div>
    </div>
    
  </div></section>
  <section class="relative overflow-hidden py-24 text-center border-t border-border"><div class="wrap max-w-xl relative z-10"><h2 class="mb-4">Need This Service?</h2><p class="text-text-secondary text-lg mb-10">Free assessment — honest advice on what's possible.</p><a href="/contact/" class="btn-primary text-[15px] px-8 py-4">Get Your Free Assessment →</a></div></section>
</BaseLayout>