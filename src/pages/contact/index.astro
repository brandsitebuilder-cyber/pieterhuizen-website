---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact — Free Consultation" description="Contact Cape Town's town planning consultants. Phone, email, WhatsApp or use our form.">
  <section class="min-h-[40vh] flex items-center"><div class="wrap pt-32 pb-12 max-w-xl"><span class="tag mb-6">Contact</span><h1>Let's <span class="text-brand">talk</span></h1><p class="text-muted text-lg mt-6">Free consultation — response within 24 hours.</p></div></section>
  <section class="py-24 bg-surface"><div class="wrap"><div class="grid md:grid-cols-5 gap-16">
    <div class="md:col-span-3">
      <form action="https://formspree.io/f/your-form-id" method="POST" class="space-y-5">
        <div><label class="form-label">Name *</label><input type="text" name="name" required class="form-input"></div>
        <div class="grid sm:grid-cols-2 gap-5"><div><label class="form-label">Email *</label><input type="email" name="email" required class="form-input"></div><div><label class="form-label">Phone</label><input type="tel" name="phone" class="form-input"></div></div>
        <div><label class="form-label">Service</label><select name="service" class="form-input"><option>Select...</option><option>Rezoning</option><option>Subdivisions</option><option>Departures</option><option>Title Deed</option><option>Development Report</option><option>Other</option></select></div>
        <div><label class="form-label">Property Location</label><input type="text" name="location" placeholder="e.g., Somerset West" class="form-input"></div>
        <div><label class="form-label">Your Project</label><textarea name="message" rows="4" class="form-input"></textarea></div>
        <button type="submit" class="btn-gold w-full justify-center text-base py-4">Send Enquiry</button>
      </form>
    </div>
    <div class="md:col-span-2 space-y-3">
      <div class="card"><div class="text-xl mb-1">📞</div><p class="font-semibold"><a href="tel:+27218523456" class="text-ink hover:text-brand">021 852 3456</a></p><p class="text-muted text-xs mt-1">Mon–Fri 8–5</p></div>
      <div class="card"><div class="text-xl mb-1">📧</div><p class="font-semibold"><a href="mailto:info@pieterhuizen.co.za" class="text-ink hover:text-brand">info@pieterhuizen.co.za</a></p></div>
      <div class="card"><div class="text-xl mb-1">💬</div><p class="font-semibold"><a href="https://wa.me/27821234567" class="text-ink hover:text-brand">082 123 4567</a></p></div>
      <div class="card"><div class="text-xl mb-1">📍</div><p class="text-muted text-sm">Cape Town, Western Cape</p></div>
    </div>
  </div></div></section>
</BaseLayout>