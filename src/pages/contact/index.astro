---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact — Free Land Use Consultation" description="Contact Cape Town's trusted town planning consultants. Phone, email, WhatsApp or use our form.">
  <section class="min-h-[40vh] flex items-center"><div class="wrap pt-32 pb-12 max-w-2xl"><p class="tag mb-6">Get In Touch</p><h1>Request Your Free<br /><span class="text-gold">Land Use Consultation</span></h1><p class="text-ink-muted text-lg mt-6">Fill in the form or contact us directly. Response within 24 hours.</p></div></section>
  <section class="section-sm bg-white"><div class="wrap"><div class="grid md:grid-cols-5 gap-16">
    <div class="md:col-span-3">
      <form action="https://formspree.io/f/your-form-id" method="POST" class="space-y-6">
        <div><label class="form-label" for="name">Full Name *</label><input type="text" id="name" name="name" required class="form-input"></div>
        <div class="grid sm:grid-cols-2 gap-6"><div><label class="form-label" for="email">Email *</label><input type="email" id="email" name="email" required class="form-input"></div><div><label class="form-label" for="phone">Phone</label><input type="tel" id="phone" name="phone" class="form-input"></div></div>
        <div><label class="form-label" for="service">Service</label><select id="service" name="service" class="form-input"><option>Select...</option><option>Rezoning</option><option>Subdivisions</option><option>Departures</option><option>Title Deed</option><option>Development Report</option><option>Other</option></select></div>
        <div><label class="form-label" for="location">Property Location</label><input type="text" id="location" name="location" placeholder="e.g., Somerset West" class="form-input"></div>
        <div><label class="form-label" for="message">Tell Us About Your Project</label><textarea id="message" name="message" rows="5" class="form-input"></textarea></div>
        <button type="submit" class="btn-primary w-full justify-center text-base py-4">Send Your Enquiry</button>
      </form>
    </div>
    <div class="md:col-span-2 space-y-4">
      <div class="card"><div class="text-lg mb-2">📞 Phone</div><a href="tel:+27218523456" class="text-ink hover:text-gold transition-colors">021 852 3456</a><p class="text-ink-muted text-xs mt-1">Mon–Fri, 8:00–17:00</p></div>
      <div class="card"><div class="text-lg mb-2">📧 Email</div><a href="mailto:info@pieterhuizen.co.za" class="text-ink hover:text-gold transition-colors">info@pieterhuizen.co.za</a><p class="text-ink-muted text-xs mt-1">Reply within 24h</p></div>
      <div class="card"><div class="text-lg mb-2">💬 WhatsApp</div><a href="https://wa.me/27821234567" class="text-ink hover:text-gold transition-colors">082 123 4567</a></div>
      <div class="card"><div class="text-lg mb-2">📍 Office</div><p class="text-ink-muted text-sm">Cape Town, Western Cape</p></div>
    </div>
  </div></div></section>
</BaseLayout>