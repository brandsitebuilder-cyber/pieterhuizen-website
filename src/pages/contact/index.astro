---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact — Free Land Use Consultation" description="Contact Cape Town's trusted town planning consultants. Phone, email, WhatsApp or use our contact form. Free consultation.">
  <section class="relative pt-28 pb-16 text-center"><div class="wrap max-w-xl"><span class="tag mb-4">Get In Touch</span><h1 class="mt-4">Request Your Free<br /><span class="gradient-text">Land Use Consultation</span></h1><p class="text-text-secondary text-lg mt-6">Fill in the form or contact us directly. Response within 24 hours.</p></div></section>
  <section class="section-sm"><div class="wrap"><div class="grid md:grid-cols-5 gap-12">
    <div class="md:col-span-3">
      <form action="https://formspree.io/f/your-form-id" method="POST" class="space-y-5">
        <div><label class="form-label" for="name">Full Name *</label><input type="text" id="name" name="name" required class="form-input"></div>
        <div class="grid sm:grid-cols-2 gap-5"><div><label class="form-label" for="email">Email *</label><input type="email" id="email" name="email" required class="form-input"></div><div><label class="form-label" for="phone">Phone</label><input type="tel" id="phone" name="phone" class="form-input"></div></div>
        <div><label class="form-label" for="service">Service Required</label><select id="service" name="service" class="form-input"><option value="">Select...</option><option>Rezoning</option><option>Subdivisions</option><option>Departures</option><option>Title Deed</option><option>Development Report</option><option>Other</option></select></div>
        <div><label class="form-label" for="location">Property Location</label><input type="text" id="location" name="location" placeholder="e.g., Somerset West" class="form-input"></div>
        <div><label class="form-label" for="message">Tell Us About Your Project</label><textarea id="message" name="message" rows="5" class="form-input"></textarea></div>
        <button type="submit" class="btn-primary w-full justify-center text-[15px] py-4">Send Your Enquiry →</button>
      </form>
    </div>
    <div class="md:col-span-2 space-y-3">
      <div class="card flex items-start gap-4"><div class="text-2xl shrink-0">📞</div><div><h3 class="text-base mb-0.5">Phone</h3><a href="tel:+27218523456" class="text-text-secondary hover:text-accent transition-colors">021 852 3456</a><p class="text-text-muted text-xs mt-1">Mon–Fri, 8:00–17:00</p></div></div>
      <div class="card flex items-start gap-4"><div class="text-2xl shrink-0">📧</div><div><h3 class="text-base mb-0.5">Email</h3><a href="mailto:info@pieterhuizen.co.za" class="text-text-secondary hover:text-accent transition-colors">info@pieterhuizen.co.za</a><p class="text-text-muted text-xs mt-1">Reply within 24h</p></div></div>
      <div class="card flex items-start gap-4"><div class="text-2xl shrink-0">💬</div><div><h3 class="text-base mb-0.5">WhatsApp</h3><a href="https://wa.me/27821234567" class="text-text-secondary hover:text-accent transition-colors">082 123 4567</a></div></div>
      <div class="card flex items-start gap-4"><div class="text-2xl shrink-0">📍</div><div><h3 class="text-base mb-0.5">Office</h3><p class="text-text-secondary text-sm">Cape Town, Western Cape</p></div></div>
    </div>
  </div></div></section>
</BaseLayout>