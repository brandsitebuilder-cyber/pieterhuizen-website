---
interface Props { title: string; description: string; schema?: object; }
const { title, description, schema } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>{title} | Pieterhuizen Planning</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <meta property="og:title" content={title}><meta property="og:description" content={description}>
  <meta property="og:type" content="website"><meta property="og:site_name" content="Pieterhuizen Planning"><meta property="og:locale" content="en_ZA">
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
</head>
<body>
  <nav class="nav">
    <div class="wrap flex items-center justify-between py-4">
      <a href="/" class="no-underline flex items-baseline gap-2">
        <span class="w-9 h-9 bg-brand rounded-xl flex items-center justify-center text-white font-display font-bold text-sm">P</span>
        <span class="font-display text-xl font-bold text-ink">Pieterhuizen<span class="text-brand">Planning</span></span>
      </a>
      <div class="hidden lg:flex items-center gap-8">
        <a href="/" class="nav-link">Home</a>
        <a href="/about/" class="nav-link">About</a>
        <div class="relative group"><span class="nav-link cursor-pointer">Services ▾</span><div class="absolute top-full left-0 mt-2 w-52 bg-surface border border-border rounded-2xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2"><a href="/services/rezoning/" class="block px-5 py-2.5 text-sm text-muted hover:text-ink hover:bg-bg">Rezoning</a><a href="/services/subdivisions/" class="block px-5 py-2.5 text-sm text-muted hover:text-ink hover:bg-bg">Subdivisions</a><a href="/services/departures/" class="block px-5 py-2.5 text-sm text-muted hover:text-ink hover:bg-bg">Departures</a><a href="/services/title-deed-restrictions/" class="block px-5 py-2.5 text-sm text-muted hover:text-ink hover:bg-bg">Title Deed</a><a href="/services/development-reports/" class="block px-5 py-2.5 text-sm text-muted hover:text-ink hover:bg-bg">Dev Reports</a></div></div>
        <div class="relative group"><span class="nav-link cursor-pointer">Areas ▾</span><div class="absolute top-full left-0 mt-2 w-48 bg-surface border border-border rounded-2xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2"><a href="/areas/cape-town/" class="block px-5 py-2.5 text-sm text-muted hover:text-ink hover:bg-bg">Cape Town</a><a href="/areas/somerset-west/" class="block px-5 py-2.5 text-sm text-muted hover:text-ink hover:bg-bg">Somerset West</a><a href="/areas/stellenbosch/" class="block px-5 py-2.5 text-sm text-muted hover:text-ink hover:bg-bg">Stellenbosch</a><a href="/areas/helderberg/" class="block px-5 py-2.5 text-sm text-muted hover:text-ink hover:bg-bg">Helderberg</a></div></div>
        <a href="/portfolio/" class="nav-link">Portfolio</a>
        <a href="/contact/" class="btn-gold !py-2 !px-5 !text-xs">Free Consultation</a>
      </div>
    </div>
  </nav>
  <main><slot /></main>
  <footer itemscope itemtype="https://schema.org/LocalBusiness">
    <meta itemprop="name" content="Pieterhuizen Planning"><meta itemprop="description" content="Town Planning Consultants Cape Town">
    <div class="wrap"><div class="grid md:grid-cols-3 gap-12">
      <div><h4>📍 Cape Town Office</h4><div class="space-y-1.5 text-sm" itemprop="address" itemscope itemtype="https://schema.org/PostalAddress"><p><span itemprop="addressLocality">Cape Town</span>, <span itemprop="addressRegion">Western Cape</span></p><p>📞 <a href="tel:+27218523456" itemprop="telephone">021 852 3456</a></p><p>📧 <a href="mailto:info@pieterhuizen.co.za" itemprop="email">info@pieterhuizen.co.za</a></p></div></div>
      <div><h4>🗺️ Areas</h4><ul class="space-y-1.5"><li><a href="/areas/cape-town/">Cape Town</a></li><li><a href="/areas/somerset-west/">Somerset West</a></li><li><a href="/areas/stellenbosch/">Stellenbosch</a></li><li><a href="/areas/helderberg/">Helderberg Basin</a></li></ul></div>
      <div><h4>📋 Quick Links</h4><ul class="space-y-1.5"><li><a href="/services/rezoning/">Rezoning</a></li><li><a href="/services/subdivisions/">Subdivisions</a></li><li><a href="/services/departures/">Departures</a></li><li><a href="/portfolio/">Portfolio</a></li><li><a href="/contact/">Free Consultation</a></li></ul></div>
    </div><div class="mt-12 pt-8 border-t border-white/10 text-center text-xs text-white/20">&copy; {new Date().getFullYear()} Pieterhuizen Planning.</div></div>
  </footer>
</body>
</html>
